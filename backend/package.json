{
  "name": "cipherwolf-backend",
  "version": "1.0.0",
  "description": "API server for the CipherWolf security platform.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:init": "npm run build && node dist/db-init.js"
  },
  "keywords": [
    "cipherwolf",
    "security",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
